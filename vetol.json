{
  "mode": "allowlist",
  "rules": [
    { "command": "ls", "include": ["-a"] },
    { "command": "tree" },
    { "command": "grep" },
    { "command": "touch" },
    { "command": "cp", "include": ["-n"] },
    { "command": "mv" },
    { "command": "mkdir" },
    { "command": "find" },
    { "command": "head" },
    { "command": "tail" },
    { "command": "pwd" },
    { "command": "trash" },
    { "command": "golangci-lint" },
    { "command": "go doc" },
    { "command": "go test" },
    { "command": "go build" },
    { "command": "go run cmd/vetol/main.go" },
    { "command": "bash tests/test.sh" },
    { "command": "git status" },
    { "command": "git diff" },
    { "command": "git log" },
    { "command": "git branch", "include": ["-a"] },
    { "command": "gh pr view" },
    { "command": "gh pr diff" },
    { "command": "gh pr list" }
  ]
}
